# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local NUNCA deve ser commitado (já está no .gitignore).

# ─── SMTP ───────────────────────────────────────────────────
# Provedor recomendado: Gmail com "Senha de App"
# Como gerar: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ─── DESTINATÁRIO ────────────────────────────────────────────
# E-mail que vai receber as mensagens do formulário
CONTACT_EMAIL=contato@ludmilabuorschiet.com.br

# ─── SEGURANÇA ───────────────────────────────────────────────
# Domínio do site em produção (evita requisições de outros domínios)
ALLOWED_ORIGIN=https://portfolio-ludmila.vercel.app
